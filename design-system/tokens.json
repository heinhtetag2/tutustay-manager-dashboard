{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "TutuStay Hotel Manager — design tokens (DTCG format). Two tiers: `palette` (primitive, theme-invariant) and `semantic` (what UI references). Re-theme by re-pointing semantic aliases. Compatible with Tokens Studio for Figma and Style Dictionary.",

  "palette": {
    "$description": "Tier 1 — primitive ramps. Never reference these directly in product UI; reference the semantic tier.",
    "constants": {
      "dark":  { "$type": "color", "$value": "#2b2826" },
      "light": { "$type": "color", "$value": "#ffffff" }
    },
    "sand": {
      "$description": "Neutral ink + surfaces.",
      "0":  { "$type": "color", "$value": "#ffffff" },
      "10": { "$type": "color", "$value": "#f8f7f7" },
      "20": { "$type": "color", "$value": "#ebebea" },
      "30": { "$type": "color", "$value": "#d8d6d4" },
      "40": { "$type": "color", "$value": "#b0adab" },
      "50": { "$type": "color", "$value": "#77736e" },
      "60": { "$type": "color", "$value": "#585450" },
      "70": { "$type": "color", "$value": "#3f3c39" },
      "80": { "$type": "color", "$value": "#2b2926" },
      "90": { "$type": "color", "$value": "#000000" }
    },
    "ocean": {
      "$description": "Brand accent ramp.",
      "10": { "$type": "color", "$value": "#ecf3fe" },
      "20": { "$type": "color", "$value": "#dae5fc" },
      "30": { "$type": "color", "$value": "#a8c3eb" },
      "40": { "$type": "color", "$value": "#6697c9" },
      "50": { "$type": "color", "$value": "#447aaf" },
      "60": { "$type": "color", "$value": "#2b5782" },
      "70": { "$type": "color", "$value": "#1d3d58" },
      "80": { "$type": "color", "$value": "#122536" }
    },
    "rust": {
      "10": { "$type": "color", "$value": "#fff1ee" },
      "20": { "$type": "color", "$value": "#fedbd7" },
      "30": { "$type": "color", "$value": "#fea99f" },
      "40": { "$type": "color", "$value": "#e86f5f" },
      "50": { "$type": "color", "$value": "#d14532" },
      "60": { "$type": "color", "$value": "#9e3225" },
      "70": { "$type": "color", "$value": "#6a2419" },
      "80": { "$type": "color", "$value": "#451610" }
    },
    "pebble": {
      "10": { "$type": "color", "$value": "#f6f2ef" },
      "20": { "$type": "color", "$value": "#e8e2d8" },
      "30": { "$type": "color", "$value": "#cdbea8" },
      "40": { "$type": "color", "$value": "#a7906c" },
      "50": { "$type": "color", "$value": "#867250" },
      "60": { "$type": "color", "$value": "#66583d" },
      "70": { "$type": "color", "$value": "#493b2c" },
      "80": { "$type": "color", "$value": "#2f271c" }
    },
    "sakura": {
      "10": { "$type": "color", "$value": "#fbf0fb" },
      "20": { "$type": "color", "$value": "#f6daf5" },
      "30": { "$type": "color", "$value": "#eaa9e5" },
      "40": { "$type": "color", "$value": "#da67cf" },
      "50": { "$type": "color", "$value": "#bc44b1" },
      "60": { "$type": "color", "$value": "#8c3485" },
      "70": { "$type": "color", "$value": "#5f235b" },
      "80": { "$type": "color", "$value": "#3e1739" }
    },
    "iris": {
      "10": { "$type": "color", "$value": "#f5f1fd" },
      "20": { "$type": "color", "$value": "#e4dcf9" },
      "30": { "$type": "color", "$value": "#c3b8f4" },
      "40": { "$type": "color", "$value": "#9d84dc" },
      "50": { "$type": "color", "$value": "#7f63c5" },
      "60": { "$type": "color", "$value": "#603fab" },
      "70": { "$type": "color", "$value": "#3f2b73" },
      "80": { "$type": "color", "$value": "#291c4a" }
    },
    "moss": {
      "10": { "$type": "color", "$value": "#f1f3ec" },
      "20": { "$type": "color", "$value": "#dee5d1" },
      "30": { "$type": "color", "$value": "#b8c69a" },
      "40": { "$type": "color", "$value": "#839b55" },
      "50": { "$type": "color", "$value": "#6a7d45" },
      "60": { "$type": "color", "$value": "#4e5c33" },
      "70": { "$type": "color", "$value": "#384224" },
      "80": { "$type": "color", "$value": "#1e2b18" }
    },
    "tropic": {
      "10": { "$type": "color", "$value": "#ebf4f4" },
      "20": { "$type": "color", "$value": "#d3e7e9" },
      "30": { "$type": "color", "$value": "#99cbcc" },
      "40": { "$type": "color", "$value": "#5a9ea0" },
      "50": { "$type": "color", "$value": "#487e7f" },
      "60": { "$type": "color", "$value": "#355d5f" },
      "70": { "$type": "color", "$value": "#294343" },
      "80": { "$type": "color", "$value": "#192929" }
    },
    "evergreen": {
      "$description": "Success ramp.",
      "10": { "$type": "color", "$value": "#ebf4eb" },
      "20": { "$type": "color", "$value": "#d8e8da" },
      "30": { "$type": "color", "$value": "#a5caa9" },
      "40": { "$type": "color", "$value": "#62a265" },
      "50": { "$type": "color", "$value": "#4b814f" },
      "60": { "$type": "color", "$value": "#396039" },
      "70": { "$type": "color", "$value": "#274427" },
      "80": { "$type": "color", "$value": "#1b2d1b" }
    },
    "ember": {
      "$description": "Warning ramp.",
      "10": { "$type": "color", "$value": "#f9f1ed" },
      "20": { "$type": "color", "$value": "#f3e2d3" },
      "30": { "$type": "color", "$value": "#e4bc9b" },
      "40": { "$type": "color", "$value": "#ce8345" },
      "50": { "$type": "color", "$value": "#b16120" },
      "60": { "$type": "color", "$value": "#884411" },
      "70": { "$type": "color", "$value": "#602f0c" },
      "80": { "$type": "color", "$value": "#402007" }
    },
    "sunbeam": {
      "10": { "$type": "color", "$value": "#feffd9" },
      "30": { "$type": "color", "$value": "#faff5c" },
      "50": { "$type": "color", "$value": "#ebf212" },
      "70": { "$type": "color", "$value": "#d8e003" }
    },
    "data": {
      "$description": "Chart / data-viz ramps. Use only in visualizations, never in chrome UI.",
      "yellow":    { "40": { "$type": "color", "$value": "#ffbc05" }, "50": { "$type": "color", "$value": "#d19900" } },
      "olive":     { "40": { "$type": "color", "$value": "#8ba755" }, "50": { "$type": "color", "$value": "#678f19" } },
      "green":     { "40": { "$type": "color", "$value": "#59c08c" }, "50": { "$type": "color", "$value": "#3fa673" } },
      "turquoise": { "50": { "$type": "color", "$value": "#18a1aa" }, "60": { "$type": "color", "$value": "#137f86" } },
      "blue":      { "50": { "$type": "color", "$value": "#1762d3" } },
      "violet":    { "40": { "$type": "color", "$value": "#7c3ddd" } },
      "purple":    { "50": { "$type": "color", "$value": "#9d1ab2" } },
      "pink":      { "50": { "$type": "color", "$value": "#ca2a78" } },
      "red":       { "50": { "$type": "color", "$value": "#c94646" }, "60": { "$type": "color", "$value": "#aa3232" }, "70": { "$type": "color", "$value": "#822626" } },
      "orange":    { "50": { "$type": "color", "$value": "#d6611f" } }
    },
    "brand-external": {
      "$description": "Third-party brand affordances only (SSO/share buttons). Not product colors.",
      "hubspot":  { "10": { "$type": "color", "$value": "#ffe2db" }, "50": { "$type": "color", "$value": "#ff7a59" } },
      "linkedin": { "10": { "$type": "color", "$value": "#cee5fc" }, "50": { "$type": "color", "$value": "#0077b5" } }
    }
  },

  "semantic": {
    "$description": "Tier 2 — the only tokens product UI should reference. Each aliases a palette step.",
    "brand": {
      "primary":       { "$type": "color", "$value": "{palette.ocean.70}" },
      "primary-hover": { "$type": "color", "$value": "{palette.ocean.60}" },
      "accent":        { "$type": "color", "$value": "{palette.ocean.50}" },
      "tint":          { "$type": "color", "$value": "{palette.ocean.20}" },
      "border":        { "$type": "color", "$value": "{palette.ocean.20}" }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "{palette.sand.80}" },
      "secondary": { "$type": "color", "$value": "{palette.sand.60}" },
      "tertiary":  { "$type": "color", "$value": "{palette.sand.70}", "$description": "NOTE: currently darker than `secondary` — see recommendations.md R-7." },
      "muted":     { "$type": "color", "$value": "{palette.sand.50}" },
      "on-brand":  { "$type": "color", "$value": "{palette.constants.light}" }
    },
    "surface": {
      "base":   { "$type": "color", "$value": "{palette.sand.0}" },
      "subtle": { "$type": "color", "$value": "{palette.sand.10}" },
      "muted":  { "$type": "color", "$value": "{palette.sand.10}", "$description": "Duplicate of subtle — see recommendations.md R-7." }
    },
    "border": {
      "default": { "$type": "color", "$value": "{palette.sand.20}" },
      "strong":  { "$type": "color", "$value": "{palette.sand.30}" }
    },
    "success": {
      "default": { "$type": "color", "$value": "{palette.evergreen.60}" },
      "strong":  { "$type": "color", "$value": "{palette.evergreen.50}" },
      "tint":    { "$type": "color", "$value": "{palette.evergreen.20}" },
      "border":  { "$type": "color", "$value": "{palette.evergreen.30}" }
    },
    "danger": {
      "default": { "$type": "color", "$value": "{palette.data.red.60}" },
      "strong":  { "$type": "color", "$value": "{palette.data.red.50}" },
      "deep":    { "$type": "color", "$value": "{palette.data.red.70}" },
      "tint":    { "$type": "color", "$value": "{palette.data.red.10}" },
      "border":  { "$type": "color", "$value": "{palette.data.red.20}" }
    },
    "warning": {
      "default": { "$type": "color", "$value": "{palette.ember.60}" },
      "strong":  { "$type": "color", "$value": "{palette.ember.50}" },
      "deep":    { "$type": "color", "$value": "{palette.ember.70}" },
      "tint":    { "$type": "color", "$value": "{palette.ember.20}" },
      "border":  { "$type": "color", "$value": "{palette.ember.20}" }
    },
    "accent-violet": {
      "default": { "$type": "color", "$value": "{palette.data.violet.40}" },
      "deep":    { "$type": "color", "$value": "{palette.iris.70}" },
      "tint":    { "$type": "color", "$value": "{palette.iris.10}" }
    },
    "accent-teal": {
      "default": { "$type": "color", "$value": "{palette.data.turquoise.60}" },
      "strong":  { "$type": "color", "$value": "{palette.data.turquoise.50}" }
    }
  },

  "typography": {
    "$description": "ABC Diatype primary; Inter (Latin) + Noto Sans KR (Hangul) fallbacks.",
    "fontFamily": {
      "sans": { "$type": "fontFamily", "$value": ["ABC Diatype", "Inter", "Noto Sans KR", "ui-sans-serif", "system-ui", "-apple-system", "sans-serif"] }
    },
    "fontWeight": {
      "light":  { "$type": "fontWeight", "$value": 300 },
      "normal": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "bold":   { "$type": "fontWeight", "$value": 700 }
    },
    "fontSize": {
      "2xs":  { "$type": "dimension", "$value": "10px", "$description": "Currently arbitrary `text-[10px]` — proposed token." },
      "xs":   { "$type": "dimension", "$value": "11px", "$description": "Currently arbitrary `text-[11px]` — proposed token. (Distinct from Tailwind text-xs=12px.)" },
      "sm-":  { "$type": "dimension", "$value": "13px", "$description": "Currently arbitrary `text-[13px]` — proposed token." },
      "sm":   { "$type": "dimension", "$value": "14px" },
      "base": { "$type": "dimension", "$value": "16px" },
      "lg":   { "$type": "dimension", "$value": "18px" },
      "xl":   { "$type": "dimension", "$value": "20px" },
      "2xl":  { "$type": "dimension", "$value": "24px" },
      "3xl":  { "$type": "dimension", "$value": "30px" },
      "4xl":  { "$type": "dimension", "$value": "36px" }
    },
    "lineHeight": {
      "tight":   { "$type": "number", "$value": 1.25 },
      "default": { "$type": "number", "$value": 1.5 }
    }
  },

  "spacing": {
    "$description": "4px base grid (Tailwind default). 1 unit = 0.25rem = 4px.",
    "0":   { "$type": "dimension", "$value": "0px" },
    "0.5": { "$type": "dimension", "$value": "2px" },
    "1":   { "$type": "dimension", "$value": "4px" },
    "1.5": { "$type": "dimension", "$value": "6px" },
    "2":   { "$type": "dimension", "$value": "8px" },
    "2.5": { "$type": "dimension", "$value": "10px" },
    "3":   { "$type": "dimension", "$value": "12px" },
    "4":   { "$type": "dimension", "$value": "16px" },
    "5":   { "$type": "dimension", "$value": "20px" },
    "6":   { "$type": "dimension", "$value": "24px" },
    "8":   { "$type": "dimension", "$value": "32px" },
    "12":  { "$type": "dimension", "$value": "48px" }
  },

  "radius": {
    "$description": "Driven by --radius=0.875rem (14px). sm/md/lg/xl are computed offsets.",
    "base": { "$type": "dimension", "$value": "14px" },
    "sm":   { "$type": "dimension", "$value": "10px", "$description": "calc(base - 4px)" },
    "md":   { "$type": "dimension", "$value": "12px", "$description": "calc(base - 2px). Default for cards, buttons, inputs (808 uses)." },
    "lg":   { "$type": "dimension", "$value": "14px", "$description": "= base" },
    "xl":   { "$type": "dimension", "$value": "18px", "$description": "calc(base + 4px)" },
    "full": { "$type": "dimension", "$value": "9999px", "$description": "Pills, avatars, status dots (222 uses)." }
  },

  "shadow": {
    "$description": "Proposed elevation tokens consolidating 11 ad-hoc rgba values found in code. All use ink rgba(44,38,39,a).",
    "xs":  { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "4px",  "blur": "16px", "spread": "0px", "color": "rgba(44,38,39,0.08)" }, "$description": "Resting cards / dropdowns (10 uses)." },
    "sm":  { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "4px",  "blur": "16px", "spread": "0px", "color": "rgba(44,38,39,0.12)" } },
    "md":  { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "8px",  "blur": "28px", "spread": "0px", "color": "rgba(44,38,39,0.12)" }, "$description": "Popovers / floating panels." },
    "lg":  { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "8px",  "blur": "28px", "spread": "0px", "color": "rgba(44,38,39,0.16)" }, "$description": "Modals / toasts." },
    "drawer": { "$type": "shadow", "$value": { "offsetX": "-8px", "offsetY": "0px", "blur": "28px", "spread": "0px", "color": "rgba(44,38,39,0.10)" }, "$description": "Right-edge side sheets." }
  },

  "chart": {
    "$description": "Categorical sequence for data viz.",
    "1": { "$type": "color", "$value": "{palette.data.blue.50}" },
    "2": { "$type": "color", "$value": "{palette.data.green.50}" },
    "3": { "$type": "color", "$value": "{palette.data.yellow.40}" },
    "4": { "$type": "color", "$value": "{palette.data.violet.40}" },
    "5": { "$type": "color", "$value": "{palette.data.orange.50}" }
  }
}
